        function openDatabase() {
            return new Promise((resolve, reject) => {
                const request = indexedDB.open(DB_NAME, DB_VERSION);
                request.onerror = () => reject(request.error);
                request.onsuccess = () => {
                    db = request.result;
                    resolve(db);
                };
                request.onupgradeneeded = (ev) => {
                    const db = ev.target.result;
                    if (!db.objectStoreNames.contains('categories')) {
                        const catStore = db.createObjectStore('categories', { keyPath: 'id' });
                        catStore.createIndex('by_name', 'name', { unique: true });
                    }
                    if (!db.objectStoreNames.contains('products')) {
                        const prodStore = db.createObjectStore('products', { keyPath: 'id' });
                        prodStore.createIndex('by_category', 'categoryId');
                    }
                    if (!db.objectStoreNames.contains('comments')) {
                        const commentStore = db.createObjectStore('comments', { keyPath: 'id', autoIncrement: true });
                        commentStore.createIndex('by_product', 'productId');
                    }
                };
            });
        }

        async function seedDatabase() {
            const tx = db.transaction(['categories', 'products'], 'readwrite');
            const catStore = tx.objectStore('categories');
            const prodStore = tx.objectStore('products');
            
            const catCount = await new Promise(r => { const req = catStore.count(); req.onsuccess = () => r(req.result); });
            if (catCount === 0) {
                for (let c of DEFAULT_CATEGORIES) await catStore.add(c);
            }
            const prodCount = await new Promise(r => { const req = prodStore.count(); req.onsuccess = () => r(req.result); });
            if (prodCount === 0) {
                for (let p of DEFAULT_PRODUCTS) await prodStore.add(p);
            }
            await tx.done;
        }

        async function getAllCategories() {
            return new Promise((resolve, reject) => {
                const tx = db.transaction('categories', 'readonly');
                const req = tx.objectStore('categories').getAll();
                req.onsuccess = () => resolve(req.result);
                req.onerror = () => reject(req.error);
            });
        }

        async function getAllProducts() {
            return new Promise((resolve, reject) => {
                const tx = db.transaction('products', 'readonly');
                const req = tx.objectStore('products').getAll();
                req.onsuccess = () => resolve(req.result);
                req.onerror = () => reject(req.error);
            });
        }

        async function getCommentsByProduct(productId) {
            return new Promise((resolve, reject) => {
                const tx = db.transaction('comments', 'readonly');
                const index = tx.objectStore('comments').index('by_product');
                const req = index.getAll(productId);
                req.onsuccess = () => resolve(req.result);
                req.onerror = () => reject(req.error);
            });
        }

        async function addProduct(product) {
            const tx = db.transaction('products', 'readwrite');
            await tx.objectStore('products').add(product);
            await tx.done;
        }

        async function updateProduct(product) {
            const tx = db.transaction('products', 'readwrite');
            await tx.objectStore('products').put(product);
            await tx.done;
        }

        async function deleteProduct(id) {
            const tx = db.transaction(['products', 'comments'], 'readwrite');
            await tx.objectStore('products').delete(id);
            const commentStore = tx.objectStore('comments');
            const index = commentStore.index('by_product');
            const comments = await new Promise(r => { const req = index.getAll(id); req.onsuccess = () => r(req.result); });
            for (let c of comments) await commentStore.delete(c.id);
            await tx.done;
        }

        async function addCategory(category) {
            const tx = db.transaction('categories', 'readwrite');
            await tx.objectStore('categories').add(category);
            await tx.done;
        }

        async function addComment(comment) {
            const tx = db.transaction('comments', 'readwrite');
            await tx.objectStore('comments').add(comment);
            await tx.done;
        }

        function validateProductForm(data) {
            const errors = {};
            if (!data.name || data.name.trim().length < 3) errors.name = 'Nombre debe tener al menos 3 caracteres.';
            if (!data.price || !/^\$\d+(\.\d{2})?$/.test(data.price) && !/^\d+(\.\d{2})?$/.test(data.price)) 
                errors.price = 'Formato precio inválido (ej. $29.99 o 29.99)';
            if (!data.categoryId) errors.category = 'Seleccione una categoría.';
            if (data.image && !isValidUrl(data.image)) errors.image = 'URL de imagen no válida.';
            return errors;
        }

        function isValidUrl(string) {
            try { new URL(string); return true; } catch { return false; }
        }

        async function serverValidateProduct(product, isUpdate = false) {
            await new Promise(r => setTimeout(r, 300));
            const all = await getAllProducts();
            const exists = all.some(p => p.name.toLowerCase() === product.name.toLowerCase() && p.id !== product.id);
            if (exists) throw new Error('El nombre del juego ya existe en el catálogo.');
            return true;
        }

        const catalogDiv = document.getElementById('catalogContainer');
        const categorySelect = document.getElementById('category');
        const productForm = document.getElementById('productForm');
        const adminProductList = document.getElementById('adminProductList');
        const categoryListDiv = document.getElementById('categoryList');

        async function refreshUI() {
            await renderCatalogBySections();
            await loadCategoriesToSelect();
            await renderAdminProductTable();
            await renderCategoryChips();
        }

        async function renderCatalogBySections() {
            const products = await getAllProducts();
            const categories = await getAllCategories();
            const sectionOrder = ['FPS', 'RPG', 'RACING', 'FANTASY', 'ADVENTURE', 'GATCHA', 'SIM', 'SPORTS'];
            const grouped = {};
            categories.forEach(cat => { grouped[cat.id] = []; });
            products.forEach(p => {
                if (!grouped[p.categoryId]) grouped[p.categoryId] = [];
                grouped[p.categoryId].push(p);
            });

            let html = '';
            for (let catName of sectionOrder) {
                const cat = categories.find(c => c.name === catName);
                if (!cat) continue;
                const catProducts = grouped[cat.id] || [];
                if (catProducts.length === 0) continue;
                
                html += `<div class="section-title">🎯 ${catName}</div><div class="catalog-grid">`;
                for (let p of catProducts) {
                    const comments = await getCommentsByProduct(p.id);
                    const commentHtml = comments.slice(0, 3).map(c => `<div class="comment">💬 ${escapeHtml(c.text)}</div>`).join('');
                    html += `
                        <div class="product-card">
                            <img src="${escapeHtml(p.image || 'https://placehold.co/400x240/ccc?text=No+image')}" alt="${escapeHtml(p.name)}">
                            <div class="card-body">
                                <h3>${escapeHtml(p.name)}</h3>
                                <div style="display:flex; justify-content:space-between; align-items:center;">
                                    <span class="price">${escapeHtml(p.price)}</span>
                                    <span class="badge">${escapeHtml(p.badge || '')}</span>
                                </div>
                                <p>${escapeHtml(p.description || '')}</p>
                                <div class="comments-section">
                                    <strong>Comentarios (${comments.length})</strong>
                                    ${commentHtml}
                                    <button class="btn-outline btn-small" style="margin-top:0.5rem;" onclick="openCommentModal('${p.id}')">➕ Agregar comentario</button>
                                </div>
                            </div>
                        </div>`;
                }
                html += `</div>`;
            }
            catalogDiv.innerHTML = html || '<p>No hay juegos en el catálogo.</p>';
        }

        async function loadCategoriesToSelect() {
            const categories = await getAllCategories();
            categorySelect.innerHTML = '<option value="">Seleccione...</option>';
            categories.forEach(c => {
                const opt = document.createElement('option');
                opt.value = c.id;
                opt.textContent = c.name;
                categorySelect.appendChild(opt);
            });
        }

        async function renderAdminProductTable() {
            const products = await getAllProducts();
            const categories = await getAllCategories();
            const catMap = Object.fromEntries(categories.map(c => [c.id, c.name]));
            let html = '<table style="width:100%; border-collapse:collapse;"><tr><th>Nombre</th><th>Precio</th><th>Categoría</th><th>Acciones</th></tr>';
            products.forEach(p => {
                html += `<tr><td>${escapeHtml(p.name)}</td><td>${escapeHtml(p.price)}</td><td>${catMap[p.categoryId]||''}</td>
                    <td><button onclick="editProduct('${p.id}')">✏️</button> <button onclick="deleteProductHandler('${p.id}')">🗑️</button></td></tr>`;
            });
            html += '</table>';
            adminProductList.innerHTML = html;
        }

        async function renderCategoryChips() {
            const categories = await getAllCategories();
            categoryListDiv.innerHTML = categories.map(c => 
                `<span style="background:#eee; padding:0.3rem 1rem; border-radius:20px;">${escapeHtml(c.name)} 
                <button onclick="deleteCategory('${c.id}')" style="border:none; background:none; cursor:pointer;">❌</button></span>`
            ).join('');
        }

        window.openCommentModal = (productId) => {
            document.getElementById('commentProductId').value = productId;
            document.getElementById('commentModal').style.display = 'flex';
        };

        window.editProduct = async (id) => {
            const products = await getAllProducts();
            const product = products.find(p => p.id === id);
            if (!product) return;
            document.getElementById('productId').value = product.id;
            document.getElementById('name').value = product.name;
            document.getElementById('price').value = product.price;
            document.getElementById('category').value = product.categoryId;
            document.getElementById('badge').value = product.badge || '';
            document.getElementById('description').value = product.description || '';
            document.getElementById('image').value = product.image || '';
            document.getElementById('formTitle').textContent = '✏️ Editar juego';
            document.getElementById('admin').scrollIntoView({behavior:'smooth'});
        };

        window.deleteProductHandler = async (id) => {
            if (confirm('¿Eliminar juego y sus comentarios?')) {
                await deleteProduct(id);
                await refreshUI();
            }
        };

        window.deleteCategory = async (id) => {
            const products = await getAllProducts();
            if (products.some(p => p.categoryId === id)) {
                alert('No se puede eliminar: hay juegos en esta categoría.');
                return;
            }
            const tx = db.transaction('categories', 'readwrite');
            await tx.objectStore('categories').delete(id);
            await tx.done;
            refreshUI();
        };

        productForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const id = document.getElementById('productId').value;
            const productData = {
                id: id || (crypto.randomUUID ? crypto.randomUUID() : 'id-' + Date.now()),
                name: document.getElementById('name').value.trim(),
                price: document.getElementById('price').value.trim(),
                categoryId: document.getElementById('category').value,
                badge: document.getElementById('badge').value.trim(),
                description: document.getElementById('description').value.trim(),
                image: document.getElementById('image').value.trim()
            };
            
            const errors = validateProductForm(productData);
            document.getElementById('nameError').textContent = errors.name || '';
            document.getElementById('priceError').textContent = errors.price || '';
            document.getElementById('categoryError').textContent = errors.category || '';
            document.getElementById('imageError').textContent = errors.image || '';
            if (Object.keys(errors).length > 0) return;

            try {
                document.getElementById('serverValidationMessage').textContent = '⏳ Validando con servidor...';
                await serverValidateProduct(productData, !!id);
                document.getElementById('serverValidationMessage').textContent = '';
                
                if (id) await updateProduct(productData);
                else await addProduct(productData);
                
                productForm.reset();
                document.getElementById('productId').value = '';
                document.getElementById('formTitle').textContent = '➕ Agregar nuevo juego';
                await refreshUI();
                alert('✅ Juego guardado correctamente.');
            } catch (err) {
                document.getElementById('serverValidationMessage').textContent = `❌ ${err.message}`;
            }
        });

        document.getElementById('cancelEditBtn').addEventListener('click', () => {
            productForm.reset();
            document.getElementById('productId').value = '';
            document.getElementById('formTitle').textContent = '➕ Agregar nuevo juego';
            document.querySelectorAll('.error-message').forEach(el => el.textContent = '');
        });

        document.getElementById('addCategoryBtn').addEventListener('click', async () => {
            const name = document.getElementById('newCategoryName').value.trim().toUpperCase();
            if (!name) {
                document.getElementById('categoryFormError').textContent = 'Nombre requerido';
                return;
            }
            try {
                const id = name.toLowerCase().replace(/\s+/g, '');
                await addCategory({ id, name });
                document.getElementById('newCategoryName').value = '';
                document.getElementById('categoryFormError').textContent = '';
                refreshUI();
            } catch (e) {
                document.getElementById('categoryFormError').textContent = 'Error: ¿nombre duplicado?';
            }
        });

        document.getElementById('commentForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const productId = document.getElementById('commentProductId').value;
            const text = document.getElementById('commentText').value.trim();
            if (!text) {
                document.getElementById('commentError').textContent = 'Comentario requerido';
                return;
            }
            await addComment({ productId, text, timestamp: new Date().toISOString() });
            document.getElementById('commentModal').style.display = 'none';
            document.getElementById('commentText').value = '';
            refreshUI();
        });

        document.getElementById('closeModalBtn').addEventListener('click', ()=> {
            document.getElementById('commentModal').style.display = 'none';
        });

        document.getElementById('resetDatabaseBtn').addEventListener('click', async () => {
            if (confirm('¿Reiniciar base de datos a valores demo? Se perderán cambios.')) {
                const stores = ['products', 'categories', 'comments'];
                for (let store of stores) {
                    const tx = db.transaction(store, 'readwrite');
                    await tx.objectStore(store).clear();
                    await tx.done;
                }
                await seedDatabase();
                await refreshUI();
            }
        });

        document.getElementById('exportDatabaseBtn').addEventListener('click', async () => {
            const data = {
                products: await getAllProducts(),
                categories: await getAllCategories(),
                comments: await new Promise(r => { const tx = db.transaction('comments'); const req = tx.objectStore('comments').getAll(); req.onsuccess = () => r(req.result); })
            };
            const blob = new Blob([JSON.stringify(data, null, 2)], {type: 'application/json'});
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `catalog_sections_${new Date().toISOString().slice(0,10)}.json`;
            a.click();
        });

        // ⭐ IMPORTAR BASE DE DATOS DESDE JSON
        document.getElementById('importDatabaseBtn').addEventListener('click', () => {
            document.getElementById('importFileInput').click();
        });

        document.getElementById('importFileInput').addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;
            
            try {
                const text = await file.text();
                const data = JSON.parse(text);
                
                if (!data.categories || !data.products) {
                    throw new Error('El JSON debe contener "categories" y "products".');
                }
                
                // Limpiar todas las tablas
                const stores = ['products', 'categories', 'comments'];
                for (let store of stores) {
                    const tx = db.transaction(store, 'readwrite');
                    await tx.objectStore(store).clear();
                    await tx.done;
                }
                
                // Insertar categorías primero
                const catTx = db.transaction('categories', 'readwrite');
                for (let cat of data.categories) {
                    await catTx.objectStore('categories').add(cat);
                }
                await catTx.done;
                
                // Insertar productos
                const prodTx = db.transaction('products', 'readwrite');
                for (let prod of data.products) {
                    await prodTx.objectStore('products').add(prod);
                }
                await prodTx.done;
                
                // Insertar comentarios si existen
                if (data.comments && data.comments.length > 0) {
                    const commTx = db.transaction('comments', 'readwrite');
                    for (let comm of data.comments) {
                        await commTx.objectStore('comments').add(comm);
                    }
                    await commTx.done;
                }
                
                await refreshUI();
                alert('✅ Base de datos importada correctamente.');
            } catch (err) {
                alert('❌ Error al importar: ' + err.message);
            }
            
            // Limpiar el input para permitir reimportar el mismo archivo
            e.target.value = '';
        });

        // ⭐ GENERAR HTML DE ENTREGA (CON DATOS INCRUSTADOS)
        document.getElementById('exportHTMLBtn').addEventListener('click', async () => {
            const categories = await getAllCategories();
            const products = await getAllProducts();
            
            const newCategoriesJSON = JSON.stringify(categories, null, 4);
            const newProductsJSON = JSON.stringify(products, null, 4);
            
            const currentHTML = document.documentElement.outerHTML;
            
            let updatedHTML = currentHTML.replace(
                /const DEFAULT_CATEGORIES = \[[\s\S]*?\];/,
                `const DEFAULT_CATEGORIES = ${newCategoriesJSON};`
            );
            updatedHTML = updatedHTML.replace(
                /const DEFAULT_PRODUCTS = \[[\s\S]*?\];/,
                `const DEFAULT_PRODUCTS = ${newProductsJSON};`
            );
            
            const blob = new Blob([updatedHTML], {type: 'text/html'});
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `GameCatalog_Entrega_${new Date().toISOString().slice(0,10)}.html`;
            a.click();
            alert('✅ HTML de entrega generado con los datos actuales incrustados.');
        });

        (async function init() {
            await openDatabase();
            await seedDatabase();
            await refreshUI();
        })();

        function escapeHtml(t) { return String(t).replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'})[c]); }
    })();
</script>

