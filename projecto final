        .form-group { margin-bottom: 1rem; }
        label { font-weight: 600; display: block; margin-bottom: 0.3rem; }
        input, select, textarea {
            width: 100%;
            padding: 0.7rem;
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            font-family: inherit;
            transition: border 0.2s;
        }
        input:focus, select:focus, textarea:focus {
            border-color: var(--primary);
            outline: none;
        }
        .error-message {
            color: var(--danger);
            font-size: 0.85rem;
            margin-top: 0.2rem;
            min-height: 1.2rem;
        }
        .btn {
            background: var(--primary);
            color: white;
            border: none;
            padding: 0.8rem 1.5rem;
            border-radius: 40px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 1rem;
            box-shadow: 0 4px 6px rgba(42,117,187,0.2);
